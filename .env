# ONDC Buyer Portal - Environment Configuration

# ============================================================
# ONDC Staging Environment Configuration
# ============================================================

# Staging Registry (for subscriber registration)
VITE_ONDC_REGISTRY_URL=https://staging.registry.ondc.org/subscribe

# Staging Gateway (for Beckn API calls)
VITE_ONDC_GATEWAY_URL=https://staging.gateway.proteantech.in

# ============================================================
# SSO/Identity Configuration
# ============================================================
# Identity service for authentication (aadharcha.in SSO)
# Production: https://aadharcha.in
# Local: http://localhost:3000 (for local identity server testing)
VITE_IDENTITY_URL=https://aadharcha.in

# ============================================================
# Backend API Configuration
# ============================================================
# Your buyer portal needs a backend BAP server that:
# 1. Handles Beckn protocol communication
# 2. Manages authentication with ONDC network
# 3. Provides REST API for this frontend

# Local development (using @ondc-sdk/api-server)
VITE_API_BASE_URL=http://localhost:3001

# Production: Deploy your backend and update this URL
# VITE_API_BASE_URL=https://your-backend-api.com

# ============================================================
# ONDC Network Participant Configuration
# ============================================================
# These are used when registering with ONDC staging registry

VITE_ONDC_DOMAIN=ONDC:RET10
VITE_ONDC_COUNTRY=IND
VITE_ONDC_CITY=std:080

# Subscriber Identity (your app's identity on ONDC network)
VITE_ONDC_SUBSCRIBER_ID=ondcbuyer.netlify.app
VITE_ONDC_SUBSCRIBER_URL=https://ondcbuyer.netlify.app

# BAP (Buyer App Platform) Configuration
VITE_ONDC_BAP_ID=ondcbuyer.netlify.app
VITE_ONDC_BAP_URI=https://ondcbuyer.netlify.app

# ============================================================
# Alternative: Reference App URLs (for testing)
# ============================================================
# Note: These are React frontends, not Beckn APIs
# VITE_API_BASE_URL=https://buyer-app-preprod-v2.ondc.org
# VITE_API_BASE_URL=https://ref-app-buyer-staging-v2.ondc.org
